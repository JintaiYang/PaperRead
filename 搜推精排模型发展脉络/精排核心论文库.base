filters:
  and:
    - file.hasTag("精排论文")
    - file.ext == "md"
formulas:
  paper_label: if(short_name, short_name + " (" + year.toString() + ")", file.name)
properties:
  short_name:
    displayName: 模型
  year:
    displayName: 年份
  venue:
    displayName: 发表会议
  direction:
    displayName: 研究方向
  affiliation:
    displayName: 机构
  contribution:
    displayName: 核心贡献
  industry:
    displayName: 工业落地
  note_link:
    displayName: 论文笔记
views:
  - type: table
    name: 全部论文（按研究方向分组）
    groupBy:
      property: direction
      direction: ASC
    order:
      - year
      - short_name
      - venue
      - direction
      - affiliation
      - contribution
      - industry
      - note_link
  - type: table
    name: 按年份排序
    order:
      - year
      - short_name
      - direction
      - venue
      - affiliation
      - industry
      - note_link
    summaries:
      year: Unique
  - type: table
    name: 特征交叉方向
    filters:
      and:
        - direction == "特征交叉"
    order:
      - year
      - short_name
      - venue
      - contribution
      - industry
      - note_link
  - type: table
    name: 序列建模方向
    filters:
      and:
        - direction == "序列建模"
    order:
      - year
      - short_name
      - venue
      - contribution
      - industry
      - note_link
  - type: table
    name: 多任务学习方向
    filters:
      and:
        - direction == "多任务学习"
    order:
      - year
      - short_name
      - venue
      - contribution
      - industry
      - note_link
  - type: table
    name: Scaling Law + 生成式推荐
    filters:
      or:
        - direction == "Scaling-Law"
        - direction == "生成式推荐"
    order:
      - year
      - short_name
      - venue
      - contribution
      - industry
      - note_link
  - type: table
    name: LLM 赋能 CTR
    filters:
      and:
        - direction == "LLM赋能CTR"
    order:
      - year
      - short_name
      - venue
      - contribution
      - industry
      - note_link
